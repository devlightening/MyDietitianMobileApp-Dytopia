{
  "expo": {
    "name": "Dytopia",
    "slug": "dytopia-mobile",
    "scheme": "dytopia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/dytopia-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/dytopia-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FBF8"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "Malzemeleri otomatik tanımlamak için kameraya erişim gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Fotoğraf galerinizden yiyecek görseli seçmek için erişim gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/dytopia-logo.png",
        "backgroundColor": "#F7FBF8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mydietitian.mobileapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/dytopia-logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Malzeme barkodu ve fotoğraf taraması için kameraya erişim gerekiyor.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fotoğraf galerinizden yiyecek görseli seçmek için erişim gerekiyor.",
          "cameraPermission": "Malzemeleri otomatik tanımlamak için kameraya erişim gerekiyor."
        }
      ]
    ]
  }
}
