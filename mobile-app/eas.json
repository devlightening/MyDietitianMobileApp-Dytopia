{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.dytopia.xyz",
        "EXPO_PUBLIC_API_BASE_URL_FORCE": "1",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "15000"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.mydietitian.com",
        "EXPO_PUBLIC_API_BASE_URL_FORCE": "1",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "10000"
      }
    }
  }
}
