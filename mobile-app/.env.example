# API Base URL Configuration
# Copy this file to .env and set your backend server's LAN IP address
#
# IMPORTANT: On physical devices, localhost points to the phone itself.
# You MUST use your PC's LAN IP address (e.g., 192.168.1.40)
#
# Finding your LAN IP:
# - Windows: Run "ipconfig" and look for "IPv4 Address"
# - Mac/Linux: Run "ifconfig" or "ip addr" and look for "inet"
#
# Example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.40:5000
#
# For localhost (emulator/simulator only):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:5000