# ─────────────────────────────────────────────────────────────────────────────
# API Base URL Configuration
# Copy this file to .env, uncomment the block for your setup, then restart
# Metro with:  npx expo start --clear
#
# FORCE=1 means: use this URL as-is, skip all auto-detection, never override.
# ─────────────────────────────────────────────────────────────────────────────

# ── CLOUDFLARE TUNNEL (recommended for physical device / any network) ─────────
#
# No LAN IP needed. Works from any network. HTTPS. No port forwarding.
#
# 1. Start backend : dotnet run --launch-profile http
# 2. Start tunnel  : cloudflared tunnel --url http://localhost:5000
# 3. Copy the HTTPS URL printed by cloudflared (e.g. https://xyz.trycloudflare.com)
# 4. Paste below:
#
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=https://YOUR_TUNNEL_URL.trycloudflare.com
#
# For EAS cloud APK builds, set the same URL in:
#   eas.json → build.preview.env.EXPO_PUBLIC_API_BASE_URL
# See: docs/CLOUDFLARE_TUNNEL_SETUP.md
#
# ── PHYSICAL DEVICE TEST via LAN (same Wi-Fi) ────────────────────────────────
#
# Find your PC's LAN IP:
#   Windows : ipconfig  → "IPv4 Address" under your Wi-Fi adapter
#
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:5000

# ── Android Emulator — RECOMMENDED for local dev ──────────────────────────────
#
# `adb reverse` tunnels emulator port to host machine.
# One-time setup (re-run when emulator restarts):
#   adb reverse tcp:5000 tcp:5000
#
# Start backend  : dotnet run --launch-profile http
# Start Metro    : npx expo start --clear
#
EXPO_PUBLIC_API_BASE_URL_FORCE=1
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# ── iOS Simulator ─────────────────────────────────────────────────────────────
# iOS simulator shares the host network; 127.0.0.1 works directly.
#
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# ── Timeout (optional, default 10000ms) ───────────────────────────────────────
# EXPO_PUBLIC_API_TIMEOUT_MS=15000
