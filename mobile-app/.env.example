# API Base URL Configuration
# Copy this file to .env, uncomment the block for your setup, then restart
# Metro with: npm run start:tunnel:clear
#
# FORCE=1 means: use this URL as-is, skip auto-detection, never override.
#
# Important for physical devices:
# localhost, 127.0.0.1, and 10.0.2.2 do not point to the laptop from your phone.

# ---------------------------------------------------------------------------
# Option A: Physical Android device via phone hotspot / same Wi-Fi
# ---------------------------------------------------------------------------
# 1. Share internet from the phone.
# 2. Connect the laptop to that hotspot.
# 3. Run `ipconfig` on Windows.
# 4. Copy the IPv4 Address under the active Wi-Fi adapter.
# 5. Start backend with: dotnet run --launch-profile http
# 6. Start Expo with: npm run start:tunnel:clear
#
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_PC_IPV4:5000
# EXPO_PUBLIC_API_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Option B: Cloudflare Tunnel for backend API
# ---------------------------------------------------------------------------
# No LAN IP needed. Works from any network. HTTPS. No port forwarding.
#
# 1. Start backend : dotnet run --launch-profile http
# 2. Start tunnel  : cloudflared tunnel --url http://localhost:5000
# 3. Copy the HTTPS URL printed by cloudflared.
# 4. Start Expo    : npm run start:tunnel:clear
#
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=https://YOUR_TUNNEL_URL.trycloudflare.com
# EXPO_PUBLIC_API_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Option C: Production API
# ---------------------------------------------------------------------------
# EXPO_PUBLIC_API_BASE_URL_FORCE=1
# EXPO_PUBLIC_API_BASE_URL=https://api.mydietitian.com
# EXPO_PUBLIC_API_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Android emulator fallback
# ---------------------------------------------------------------------------
# Leave EXPO_PUBLIC_API_BASE_URL unset to auto-use http://10.0.2.2:5000.
