{
  "name": "Sample Ingredient Normalization Benchmark",
  "version": "2.0",
  "description": "Normalization benchmark — 60 cases across 6 categories: 10 exact canonical (easy), 10 alias (medium), 10 Turkish diacritic variants (medium), 10 fuzzy/Levenshtein (medium), 10 ambiguous boundary (hard), 10 LLM fallback (hard). Seeded ingredients: Tomato (alias: Domates), Yogurt (alias: Yogurt), Onion, Garlic.",
  "cases": [
    {
      "id": "can-001",
      "rawInput": "Tomato",
      "expectedCanonicalName": "Tomato",
      "expectedMatchType": "canonical",
      "difficulty": "easy",
      "notes": "Exact canonical match — Layer A."
    },
    {
      "id": "can-002",
      "rawInput": "  TOMATO  ",
      "expectedCanonicalName": "Tomato",
      "expectedMatchType": "canonical",
      "difficulty": "easy",
      "notes": "Whitespace trimming + uppercase folding."
    },
    {
      "id": "can-003",
      "rawInput": "Yoğurt",
      "expectedCanonicalName": "Yoğurt",
      "expectedMatchType": "canonical",
      "difficulty": "easy",
      "notes": "Turkish canonical with diacritic — ToLowerInvariant preserves ğ."
    },
    {
      "id": "can-004",
      "rawInput": "Onion",
      "expectedCanonicalName": "Onion",
      "expectedMatchType": "canonical",
      "difficulty": "easy",
      "notes": "Exact canonical match for Onion."
    },
