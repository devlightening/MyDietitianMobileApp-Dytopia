{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSecurity": {
    "LockoutKeySecret": "CHANGE_ME_LOCKOUT_SECRET",
    "AllowedEmailDomains": [
      "gmail.com",
      "outlook.com",
      "hotmail.com",
      "live.com",
      "icloud.com",
      "yahoo.com"
    ]
  },
  "IngredientLlm": {
    "Enabled": false,
    "ModelName": "gpt-4o-mini",
    "ApiKeyEnvVar": "OPENAI_API_KEY",
    "MaxCandidates": 12,
    "MinFuzzyScoreForShortlist": 0.55,
    "MaxInputLength": 120,
    "MinConfidenceToAccept": 0.75,
    "MinConfidenceForAmbiguous": 0.50
  }
}
