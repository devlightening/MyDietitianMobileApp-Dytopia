{
  "ContactAdmin": {
    "ApiKey": "CHANGE_ME_CONTACT_ADMIN_KEY_2026"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSecurity": {
    "LockoutKeySecret": "CHANGE_ME_LOCKOUT_SECRET",
    "AllowedEmailDomains": []
  },
  "AuthSecurity_Note": "Empty AllowedEmailDomains = use the hardcoded DefaultAllowedDomains in EmailPolicy.cs (100+ global providers). Set to [\"*\"] only in Development to allow any domain.",
  "IngredientLlm": {
    "Enabled": false,
    "Provider": "openai",
    "BaseUrl": null,
    "ModelName": "gpt-4o-mini",
    "ApiKeyEnvVar": "OPENAI_API_KEY",
    "MaxCandidates": 12,
    "MinFuzzyScoreForShortlist": 0.55,
    "MaxInputLength": 120,
    "MinConfidenceToAccept": 0.75,
    "MinConfidenceForAmbiguous": 0.50
  },
  "VisionIngredient": {
    "Enabled": false,
    "ModelName": "gpt-4o",
    "ApiKeyEnvVar": "OPENAI_API_KEY",
    "MaxDetectedItems": 20,
    "MaxImageBytes": 10485760,
    "TargetImageBytes": 3145728,
    "TimeoutSeconds": 30,
    "EnforceClosedSetInResolver": false,
    "ClosedSetCanonicalNames": [
      "Domates", "Salatalık", "Limon", "Marul", "Tavuk Göğsü", "Yumurta", "Muz",
      "Süt", "Yoğurt", "Beyaz Peynir", "Kaşar Peyniri", "Biber", "Kırmızı Biber",
      "Soğan", "Sarımsak", "Patates", "Havuç", "Kabak", "Brokoli", "Elma",
      "Portakal", "Çilek", "Yulaf", "Pirinç", "Makarna", "Ton Balığı", "Ekmek",
      "Avokado", "Ispanak", "Mantar"
    ]
  },
  "PremiumKitchenMatch": {
    "AllowGlobalPublicFallback": false
  },
  "OpenFoodFacts": {
    "Enabled": true,
    "BaseUrl": "https://world.openfoodfacts.org",
    "TimeoutSeconds": 4
  }
}
