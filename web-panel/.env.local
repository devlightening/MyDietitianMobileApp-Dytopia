# Internal API base URL for server-side requests (Next.js API routes)
# Use HTTP to avoid self-signed certificate errors in development
INTERNAL_API_BASE_URL=http://127.0.0.1:5000

# Public API base URL for client-side requests (browser)
# Use HTTP in development to avoid SSL certificate errors
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000
